{
  "name": "latrics-crm",
  "version": "1.0.0",
  "description": "Root package for Latrics CRM",
  "scripts": {
    "client-install": "npm.cmd install --prefix client",
    "server-install": "npm.cmd install --prefix server",
    "install-all": "npm.cmd run client-install && npm.cmd run server-install",
    "client": "npm.cmd run dev --prefix client",
    "server": "npm.cmd run dev --prefix server",
    "dev": "concurrently \"npm.cmd run server\" \"npm.cmd run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
